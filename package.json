{
  "name": "adv-auth-flow",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "set \"EXPO_NO_DEPENDENCY_VALIDATION=1\"&& expo start",
    "start:clean": "set \"EXPO_NO_DEPENDENCY_VALIDATION=1\"&& expo start -c",
    "android": "set \"EXPO_NO_DEPENDENCY_VALIDATION=1\"&& expo start --android",
    "ios": "set \"EXPO_NO_DEPENDENCY_VALIDATION=1\"&& expo start --ios",
    "web": "set \"EXPO_NO_DEPENDENCY_VALIDATION=1\"&& expo start --web"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "@react-native-async-storage/async-storage": "2.1.2",
    "expo": "~53.0.0",
    "expo-auth-session": "~6.2.1",
    "expo-image-picker": "~16.1.4",
    "expo-router": "~5.1.11",
    "expo-status-bar": "~2.2.3",
    "expo-web-browser": "~14.2.0",
    "firebase": "^12.11.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.54.2",
    "react-native": "0.79.6",
    "react-native-web": "^0.20.0"
  },
  "devDependencies": {
    "@types/react": "~19.0.10",
    "typescript": "~5.8.3"
  }
}
